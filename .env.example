# Минимум для запуска (остальное можно не трогать):
BOT_TOKEN=ваш_токен_от_BotFather

# Опционально: Postgres вместо SQLite
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/botdb

# Опционально: закрытый канал (отрицательный id). 0 = не настроено
CHANNEL_ID=0

# Опционально: Telegram Payments (BotFather → Payments)
PAYMENTS_TOKEN=

# Нет PAYMENTS_TOKEN: true = сразу сценарий «оплата прошла» (как будет выглядеть у пользователя)
MOCK_PAYMENTS=true

# Опционально: ЮKassa (автосписания)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Опционально: админы / поддержка
ADMIN_IDS=
SUPPORT_USERNAME=@melon_edu

LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
